{
	"taskDefinitionArn": "arn:aws:ecs:us-east-1:866934333672:task-definition/prab-eks-backend-stage:1",
	"containerDefinitions": [
		{
			"name": "flask-api",
			"image": "866934333672.dkr.ecr.us-east-1.amazonaws.com/prab-cicd-backend:5a14cc1533488a4aa7187aaf0d779d77c71801e9",
			"cpu": 768,
			"memory": 1536,
			"portMappings": [
				{
					"containerPort": 80,
					"hostPort": 80,
					"protocol": "tcp",
					"name": "backend-api-80-tcp"
				}
			],
			"essential": true,
			"environment": [
				{
					"name": "AWS_REGION",
					"value": "us-east-1"
				},
				{
					"name": "ENVIRONMENT",
					"value": "stage"
				},
				{
					"name": "OTEL_EXPORTER_OTLP_ENDPOINT",
					"value": "http://localhost:4317"
				}
			],
			"mountPoints": [],
			"volumesFrom": [],
			"dependsOn": [
				{
					"containerName": "splunk-otel-collector",
					"condition": "START"
				}
			],
			"readonlyRootFilesystem": false,
			"logConfiguration": {
				"logDriver": "awslogs",
				"options": {
					"awslogs-group": "/ecs/stage/prab-cicd-backend",
					"awslogs-create-group": "true",
					"awslogs-region": "us-east-1",
					"awslogs-stream-prefix": "ecs-backend-stage"
				}
			},
			"healthCheck": {
				"command": [
					"CMD-SHELL",
					"python3 -c 'import urllib.request; urllib.request.urlopen(\"http://localhost:80/health\")' || exit 1"
				],
				"interval": 30,
				"timeout": 5,
				"retries": 3,
				"startPeriod": 120
			},
			"systemControls": []
		},
		{
			"name": "splunk-otel-collector",
			"image": "quay.io/signalfx/splunk-otel-collector:latest",
			"cpu": 256,
			"memory": 512,
			"portMappings": [
				{
					"containerPort": 4317,
					"hostPort": 4317,
					"protocol": "tcp",
					"name": "otel-grpc-4317"
				},
				{
					"containerPort": 4318,
					"hostPort": 4318,
					"protocol": "tcp",
					"name": "otel-http-4318"
				}
			],
			"essential": false,
			"environment": [
				{
					"name": "SPLUNK_INSECURE_SKIP_VERIFY",
					"value": "TRUE"
				},
				{
					"name": "SPLUNK_HEC_URL",
					"value": "https://prd-p-ykpou.splunkcloud.com:8088/v1/collector"
				},
				{
					"name": "SPLUNK_REALM",
					"value": "us0"
				},
				{
					"name": "ECS_METADATA_EXCLUDED_IMAGES",
					"value": "[\"quay.io/signalfx/splunk-otel-collector*\"]"
				}
			],
			"mountPoints": [],
			"volumesFrom": [],
			"secrets": [
				{
					"name": "SPLUNK_ACCESS_TOKEN",
					"valueFrom": "arn:aws:ssm:us-east-1:866934333672:parameter/prab/aws-ecs-cicd/splunk/access_token"
				},
				{
					"name": "SPLUNK_CONFIG",
					"valueFrom": "arn:aws:ssm:us-east-1:866934333672:parameter/prab/aws-ecs-cicd/splunk/dev/config"
				}
			],
			"logConfiguration": {
				"logDriver": "awslogs",
				"options": {
					"awslogs-group": "/ecs/stage/prab-cicd-backend",
					"awslogs-create-group": "true",
					"awslogs-region": "us-east-1",
					"awslogs-stream-prefix": "ecs-splunk-sidecar"
				}
			},
			"systemControls": []
		}
	],
	"family": "prab-cicd-ecs-backend-stage",
	"taskRoleArn": "arn:aws:iam::866934333672:role/prab-cicd-backend-task-role",
	"executionRoleArn": "arn:aws:iam::866934333672:role/prab-cicd-backend-task-execution-role",
	"networkMode": "awsvpc",
	"revision": 21,
	"volumes": [],
	"status": "ACTIVE",
	"requiresAttributes": [
		{
			"name": "ecs.capability.execution-role-awslogs"
		},
		{
			"name": "com.amazonaws.ecs.capability.ecr-auth"
		},
		{
			"name": "com.amazonaws.ecs.capability.task-iam-role"
		},
		{
			"name": "ecs.capability.container-health-check"
		},
		{
			"name": "ecs.capability.execution-role-ecr-pull"
		},
		{
			"name": "ecs.capability.secrets.ssm.environment-variables"
		},
		{
			"name": "com.amazonaws.ecs.capability.docker-remote-api.1.18"
		},
		{
			"name": "ecs.capability.task-eni"
		},
		{
			"name": "com.amazonaws.ecs.capability.docker-remote-api.1.29"
		},
		{
			"name": "com.amazonaws.ecs.capability.logging-driver.awslogs"
		},
		{
			"name": "com.amazonaws.ecs.capability.docker-remote-api.1.19"
		},
		{
			"name": "ecs.capability.container-ordering"
		}
	],
	"placementConstraints": [],
	"compatibilities": ["EC2", "FARGATE", "MANAGED_INSTANCES"],
	"runtimePlatform": {
		"cpuArchitecture": "X86_64",
		"operatingSystemFamily": "LINUX"
	},
	"requiresCompatibilities": ["FARGATE"],
	"cpu": "1024",
	"memory": "2048",
	"tags": []
}
